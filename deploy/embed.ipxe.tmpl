#!ipxe
# Polyptic boot medium, the embedded script baked into polyptic-boot-<arch>.efi by build-ipxe.sh.
# @@POLYPTIC_BASE@@ is replaced with the control-plane base URL at BUILD time; ${...} are iPXE runtime
# variables and must survive verbatim. TOKENLESS: this carries only the base URL. The enrolment token is
# baked by GET /boot.ipxe at chain time (so the site-DHCP / UEFI-HTTP-boot paths, which have no medium,
# still get it). Ownership is by key: whoever can make a box chain ${base}/boot.ipxe enrols it.
set base @@POLYPTIC_BASE@@

:start
dhcp || goto netfail

menu Polyptic netboot  --  ${base}
item --gap --                     Boot the Polyptic kiosk image:
item dongle    Boot now  (keep this dongle plugged in)
item offload   Offload to this box, then boot  (one-time; writes a tiny loader to the ESP)
item --gap --                     ----
item shell     iPXE command shell
item reboot    Reboot
choose --default dongle --timeout 5000 target || goto dongle
goto ${target}

:dongle
# Diskless: chain the control plane's script. It bakes the token + kernel cmdline and streams
# vmlinuz/initrd/squashfs into RAM. NOTHING is written to this machine.
echo Booting from ${base}/boot.ipxe ...
chain ${base}/boot.ipxe || goto bootfail

:offload
# The live image performs the offload (iPXE itself cannot write a local ESP or run efibootmgr). We ask
# for it by chaining boot.ipxe?offload=1; the server adds polyptic.offload=1 to the kernel cmdline, and
# the image's polyptic-offload.service drops the loader into the existing ESP + adds a UEFI boot entry
# (never repartitions/wipes). After that, pull the USB, the box self-boots the identical flow forever.
echo Offload: booting the live image in one-time offload mode ...
chain ${base}/boot.ipxe?offload=1 || goto bootfail

:shell
echo Type 'exit' to return to the menu.
shell
goto start

:reboot
reboot

:netfail
echo DHCP failed - no network. Dropping to an iPXE shell.
shell
goto start

:bootfail
echo Could not reach ${base}/boot.ipxe. Check the network / server. Dropping to an iPXE shell.
shell
goto start
