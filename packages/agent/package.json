{
  "name": "@polyptych/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Polyptych per-client agent — dumb reconciler that registers a machine's outputs and points a player at each screen.",
  "main": "./src/index.ts",
  "bin": {
    "polyptych-agent": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "setup": "bun src/index.ts setup",
    "setup:dry": "bun src/index.ts setup --dry-run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@polyptych/protocol": "workspace:*",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.5.0"
  }
}
