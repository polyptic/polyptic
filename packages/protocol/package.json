{
  "name": "@polyptych/protocol",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shared zod contracts for Polyptych — the single source of truth for all cross-process messages.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "zod": "^3.23.0"
  }
}
